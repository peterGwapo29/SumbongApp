# Root .gitignore for SumbongApp Project
# This file covers common files that should not be committed to Git

# ============================================
# Operating System Files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ============================================
# IDE and Editor Files
# ============================================
# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains IDEs (PhpStorm, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*.swn

# Emacs
*~
\#*\#
.\#*

# ============================================
# Environment Variables
# ============================================
.env
.env.local
.env.*.local
.env.backup
.env.production

# ============================================
# Logs
# ============================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Temporary Files
# ============================================
*.tmp
*.temp
*.cache
.cache/

# ============================================
# Package Manager Files
# ============================================
# Note: package-lock.json and composer.lock should be committed
# They ensure consistent dependency versions

# yarn
.yarn/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# pnpm
.pnpm-store/

# ============================================
# Build and Distribution
# ============================================
dist/
build/
out/
.next/
.vercel/

# ============================================
# Database
# ============================================
*.sqlite
*.sqlite3
*.db

# ============================================
# Backup Files
# ============================================
*.bak
*.backup
*.old

# ============================================
# Documentation Build
# ============================================
docs/_build/
site/

# ============================================
# Testing
# ============================================
coverage/
.nyc_output/
*.lcov
.phpunit.result.cache
.phpunit.cache/

# ============================================
# Misc
# ============================================
*.pem
*.key
*.cert
*.crt
auth.json
composer.phar

# ============================================
# Project Specific
# ============================================
# Keep the Backend and Frontend .gitignore files
# They handle their specific directories

